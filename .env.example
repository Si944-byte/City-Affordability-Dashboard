# City Affordability Dashboard — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it is in .gitignore

# -------------------------------------------------------
# SQL Server Configuration
# -------------------------------------------------------
# Your SQL Server instance name
# Examples: localhost, DESKTOP-XXXXXXX, myserver\SQLEXPRESS
SQL_SERVER=your_server_name_here

# Database name (default: CityAffordability)
SQL_DATABASE=CityAffordability

# Leave blank for Windows Authentication (recommended for local SQL Server)
# Fill in for SQL Server Authentication
SQL_USERNAME=
SQL_PASSWORD=

# -------------------------------------------------------
# API Keys
# -------------------------------------------------------
# Census ACS API Key — free at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# BLS API Key — free at https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# HUD API Key — free at https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_KEY=your_hud_api_key_here

# FRED API Key — free at https://fred.stlouisfed.org/docs/api/api_key.html
# Optional — FRED has a CSV fallback that does not require a key
FRED_API_KEY=your_fred_api_key_here
